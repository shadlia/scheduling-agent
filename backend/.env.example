# ============================================
# Voice Scheduling Agent - Environment Variables
# ============================================

# Google Gemini API Key (free)
# Get yours at: https://aistudio.google.com/apikey
GEMINI_API_KEY=your_gemini_api_key_here

# ─── LangSmith (Optional, for tracing & graph visualization) ───
# Sign up free at: https://smith.langchain.com/
LANGCHAIN_TRACING_V2=true
LANGCHAIN_API_KEY=your_langsmith_api_key_here
LANGCHAIN_PROJECT=voice-scheduling-agent

# ─── Google Calendar (Optional for initial testing) ───
# The calendar ID to create events on (usually your email)
GOOGLE_CALENDAR_ID=your_email@gmail.com

# Path to Google Service Account credentials JSON file
# Download from Google Cloud Console > APIs & Services > Credentials
GOOGLE_SERVICE_ACCOUNT_FILE=credentials/service_account.json

# Backend Configuration
BACKEND_PORT=8000
FRONTEND_URL=http://localhost:5173
